# ─────────────────────────────────────────────────────────────
# KiramoPay Frontend — Variables de Entorno
# ─────────────────────────────────────────────────────────────
# Copiar este archivo a .env.local:
#   cp .env.example .env.local
#
# Las variables con prefijo VITE_ están disponibles en el código
# frontend via import.meta.env.VITE_*
# Las variables sin prefijo se exponen mediante vite.config.ts define.
# ─────────────────────────────────────────────────────────────

# ── API Backend ──────────────────────────────────────────────
# URL del backend API. Si NO se define, la app usa mock adapters
# (datos simulados en localStorage) — ideal para desarrollo sin backend.
# Si se define, la app usa HTTP adapters que conectan al backend real.
#
# Ejemplos:
#   VITE_API_URL=http://localhost:8080       # Backend local
#   VITE_API_URL=http://kiramopay.local      # Kubernetes (minikube)
#   VITE_API_URL=https://api.kiramopay.com   # Producción
VITE_API_URL=

# ── Push Notifications (PWA) ────────────────────────────────
# Clave pública VAPID para push notifications.
# Generar un par de claves con:
#   npx web-push generate-vapid-keys
# La clave privada va en el backend (VAPID_PRIVATE_KEY).
# Si no se define, push notifications se deshabilitan silenciosamente.
VITE_VAPID_PUBLIC_KEY=

# ── Asistente conversacional (proveedor de LLM) ──────────────
# El asistente del backend usa un proveedor de LLM. Si no se setea ninguna
# key, el asistente reporta "no disponible" (no rompe nada).
#
# Claude (Anthropic) — TIENE PRECEDENCIA sobre Gemini si ambas keys están.
# Obtener en: https://console.anthropic.com/  ·  modelo por defecto claude-opus-4-8
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8   # opcional (p. ej. claude-haiku-4-5 por costo)
#
# Gemini (Google) — alternativa; se usa solo si no hay ANTHROPIC_API_KEY.
# Obtener en: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash     # opcional
