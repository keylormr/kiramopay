# ─────────────────────────────────────────────────────────────
# KiramoPay Frontend — Variables de Entorno
# ─────────────────────────────────────────────────────────────
# Copiar este archivo a .env.local:
#   cp .env.example .env.local
#
# Las variables con prefijo VITE_ están disponibles en el código
# frontend via import.meta.env.VITE_*
# Las variables sin prefijo se exponen mediante vite.config.ts define.
# ─────────────────────────────────────────────────────────────

# ── API Backend ──────────────────────────────────────────────
# URL del backend API. Si NO se define, la app usa mock adapters
# (datos simulados en localStorage) — ideal para desarrollo sin backend.
# Si se define, la app usa HTTP adapters que conectan al backend real.
#
# Ejemplos:
#   VITE_API_URL=http://localhost:8080       # Backend local
#   VITE_API_URL=http://kiramopay.local      # Kubernetes (minikube)
#   VITE_API_URL=https://api.kiramopay.com   # Producción
VITE_API_URL=

# ── Push Notifications (PWA) ────────────────────────────────
# Clave pública VAPID para push notifications.
# Generar un par de claves con:
#   npx web-push generate-vapid-keys
# La clave privada va en el backend (VAPID_PRIVATE_KEY).
# Si no se define, push notifications se deshabilitan silenciosamente.
VITE_VAPID_PUBLIC_KEY=

# ── Descarga de la app Android ──────────────────────────────
# URL del APK que enlaza el boton "Descargar aplicacion Android" del login.
# Si no se define, usa el asset "latest" de GitHub Releases publicado por el
# workflow .github/workflows/android-apk.yml. Ver docs/ANDROID_APK.md.
VITE_ANDROID_APK_URL=

# ── Asistente conversacional (proveedor de LLM) ──────────────
# El asistente del backend usa un proveedor de LLM. Si no se setea ninguna
# key, el asistente reporta "no disponible" (no rompe nada).
#
# Claude (Anthropic) — TIENE PRECEDENCIA sobre Gemini si ambas keys están.
# Obtener en: https://console.anthropic.com/  ·  modelo por defecto claude-opus-4-8
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8   # opcional (p. ej. claude-haiku-4-5 por costo)
#
# Gemini (Google) — alternativa; se usa solo si no hay ANTHROPIC_API_KEY.
# Obtener en: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash     # opcional

# ─────────────────────────────────────────────────────────────
# Backend — variables de seguridad (NO van al bundle del frontend)
# ─────────────────────────────────────────────────────────────
#
# Seeding de usuarios demo fuera de development: las contraseñas demo
# hardcodeadas SOLO se usan en ENVIRONMENT=development. Si activás SEED_DEMO=true
# en cualquier otro entorno, cada usuario demo se siembra SOLO si su contraseña
# viene de SEED_PASSWORD_<CEDULA> (sin fallback). Sin estas vars, el usuario se
# omite (evita una cuenta admin con contraseña pública en producción).
#   SEED_PASSWORD_700000000=<contraseña-fuerte-del-admin>
#   SEED_PASSWORD_702650930=<contraseña-fuerte-de-keilor>
#
# /metrics: opcionalmente protegido por token (si vacío, queda abierto para el
# scrape de Prometheus). Si se setea, pedir `Authorization: Bearer <token>`.
#   METRICS_TOKEN=
#
# ── Mensajería: entrega real de OTP y recuperación (SMS + email) ─────────────
# Cada proveedor es OPCIONAL. Sin configurar, el código/token de verificación
# solo se hace eco en ENVIRONMENT=development (nunca en producción). Al pegar las
# llaves, el envío real se activa sin más cambios de código.
#
# SMS por Telnyx (OTP de registro + código de autorización de montos altos):
#   SMS_PROVIDER=telnyx
#   TELNYX_API_KEY=<api key de https://portal.telnyx.com>
#   TELNYX_FROM=+15550001111                 # número emisor E.164
#   # o, en vez de un número fijo, un messaging profile que enruta el número:
#   # TELNYX_MESSAGING_PROFILE_ID=<uuid del messaging profile>
#
# Email por Amazon SES (token de recuperación de contraseña), vía SMTP+STARTTLS:
#   EMAIL_PROVIDER=ses
#   SES_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
#   SES_SMTP_PORT=587
#   SES_SMTP_USER=<usuario SMTP de SES>
#   SES_SMTP_PASSWORD=<contraseña SMTP de SES>
#   EMAIL_FROM=KiramoPay <no-reply@kiramopay.com>   # remitente verificado en SES
#
# URL pública del frontend, para armar el enlace de recuperación en el email:
#   PUBLIC_APP_URL=https://kiramopay.vercel.app
#
# Exigir teléfono verificado en el registro (requiere SMS_PROVIDER configurado;
# el arranque falla si se activa sin proveedor de SMS):
#   REQUIRE_PHONE_VERIFICATION=false
#
# En producción, ValidateForProduction exige además: JWT_SECRET real (>=32),
# DB_SSL_MODE != disable, DB_PASSWORD != default, REDIS_PASSWORD seteado, y
# CORS_ORIGINS con allowlist explícita (no '*').
