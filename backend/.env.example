# Server
ENVIRONMENT=development
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10
SERVER_WRITE_TIMEOUT=10

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=kiramopay
DB_PASSWORD=kiramopay_dev
DB_NAME=kiramopay
DB_SSL_MODE=disable
DB_MAX_CONNS=25
# SSL certificates (production only)
# DB_SSL_ROOT_CERT=/etc/ssl/certs/rds-ca.pem
# DB_SSL_CERT=
# DB_SSL_KEY=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=kiramopay_redis_dev
REDIS_DB=0

# JWT
JWT_SECRET=dev-secret-change-in-production
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:*,https://localhost:*

# Push Notifications (VAPID keys)
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# Exchange Rates
# EXCHANGE_RATE_API_KEY=
# EXCHANGE_RATE_INTERVAL=15m

# CoinGecko (optional, for higher rate limits)
# COINGECKO_API_KEY=
